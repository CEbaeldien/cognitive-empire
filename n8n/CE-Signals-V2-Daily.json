    {
      "id": "v2-ok",
      "name": "Log Success",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2660, 220],
      "parameters": {
        "jsCode": "const e1 = $('Enrich Run 1').first().json;\nconst e2 = $('Enrich Run 2').first().json;\nconst e3 = $('Enrich Run 3').first().json;\nconst e4 = $('Enrich Run 4').first().json;\nconst e5 = $('Enrich Run 5').first().json;\nconst b1 = $('Batch Run 1').first().json;\nconst b2 = $('Batch Run 2').first().json;\nconst b3 = $('Batch Run 3').first().json;\nconst cl = $('Cluster Run').first().json;\nconst summary = {\n  enrich: {\n    total_checked:  (e1.items_checked  || 0) + (e2.items_checked  || 0) + (e3.items_checked  || 0) + (e4.items_checked  || 0) + (e5.items_checked  || 0),\n    total_enriched: (e1.items_enriched || 0) + (e2.items_enriched || 0) + (e3.items_enriched || 0) + (e4.items_enriched || 0) + (e5.items_enriched || 0),\n    total_skipped:  (e1.items_skipped  || 0) + (e2.items_skipped  || 0) + (e3.items_skipped  || 0) + (e4.items_skipped  || 0) + (e5.items_skipped  || 0),\n    total_failed:   (e1.items_failed   || 0) + (e2.items_failed   || 0) + (e3.items_failed   || 0) + (e4.items_failed   || 0) + (e5.items_failed   || 0),\n  },\n  batch: {\n    runs: [b1.run_id, b2.run_id, b3.run_id],\n    total_input:  (b1.input_count  || 0) + (b2.input_count  || 0) + (b3.input_count  || 0),\n    total_output: (b1.output_count || 0) + (b2.output_count || 0) + (b3.output_count || 0),\n    total_noise:  (b1.noise_count  || 0) + (b2.noise_count  || 0) + (b3.noise_count  || 0),\n    total_errors: (b1.error_count  || 0) + (b2.error_count  || 0) + (b3.error_count  || 0),\n    doctrine_version: b3.doctrine_version,\n  },\n  cluster: {\n    atoms_processed:  cl.atoms_processed,\n    clusters_created: cl.clusters_created,\n    clusters_updated: cl.clusters_updated,\n    clusters_matured: cl.clusters_matured,\n    clusters_expired: cl.clusters_expired,\n    soft_errors:      (cl.errors || []).length,\n  },\n};\nconsole.log('[CE Signals V2] Daily run complete:', JSON.stringify(summary));\nreturn [{ json: { ...summary, success: true } }];"
      }
    },
    {
      "id": "v2-err",
      "name": "Log Cluster Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2660, 400],
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconsole.log('[CE Signals V2] Cluster error:', JSON.stringify(result));\nreturn [{ json: { error: result.error || 'unknown', success: false } }];"
      }
    }
