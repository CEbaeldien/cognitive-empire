    {
      "parameters": {
        "method": "GET",
        "url": "={{ `https://qgykfjnuaowcyiuzdvsa.supabase.co/rest/v1/signals?status=eq.published&published_at=lt.${new Date(Date.now() - 14*24*60*60*1000).toISOString()}&select=id,decay_factor` }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
