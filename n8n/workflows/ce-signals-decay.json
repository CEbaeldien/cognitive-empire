      },
      "id": "c3000004-0002-4000-8000-000000000004",
      "name": "Get Stale Published Signals",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "const signals = $input.first().json;\nif (!Array.isArray(signals) || signals.length === 0) {\n  console.log('[Decay] No signals eligible for decay');\n  return [];\n}\nreturn signals.map(signal => {\n  const current = typeof signal.decay_factor === 'number' ? signal.decay_factor : 0;\n  const newDecay = Math.min(parseFloat((current + 0.1).toFixed(2)), 1.0);\n  const updateBody = { decay_factor: newDecay };\n  if (newDecay >= 0.8) updateBody.status = 'decaying';\n  return {\n    json: {\n      id: signal.id,\n      old_decay: current,\n      new_decay: newDecay,\n      marking_decaying: newDecay >= 0.8,\n      update_body: JSON.stringify(updateBody)\n    }\n  };\n});"
      },
      "id": "c3000004-0003-4000-8000-000000000004",
      "name": "Compute Decay Values",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ `https://qgykfjnuaowcyiuzdvsa.supabase.co/rest/v1/signals?id=eq.${$json.id}` }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "sb_secret_nGFx1BL5M8sreweA_GZtCQ_usvvMF0S"
            },
